---
// Self-contained Conway's Game of Life, scoped to its own card canvas.
// Colors pulled from the aurora palette so it blends into the bento.
---

<canvas class="gol-canvas" data-gol aria-hidden="true"></canvas>

<script>
  // Scope: find every canvas tagged [data-gol] and start an independent sim.
  // Resizes via ResizeObserver; pauses when off-screen (IntersectionObserver).
  type Grid = Uint8Array;

  function startGol(canvas: HTMLCanvasElement) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // aurora-palette cell colors (alpha baked in)
    const palette = [
      'rgba(255, 138, 91, 0.55)',   // coral
      'rgba(255, 184, 107, 0.50)',  // peach
      'rgba(245, 215, 110, 0.50)',  // gold
      'rgba(255, 107, 157, 0.55)',  // rose
      'rgba(201, 53, 111, 0.55)',   // deep rose
    ];

    const cellSize = 9;
    let cols = 0;
    let rows = 0;
    let current: Grid = new Uint8Array(0);
    let next: Grid = new Uint8Array(0);
    let dpr = Math.min(window.devicePixelRatio || 1, 2);

    function idx(x: number, y: number) {
      return y * cols + x;
    }

    function seed() {
      for (let i = 0; i < current.length; i++) {
        current[i] = Math.random() < 0.22 ? 1 : 0;
      }
    }

    function resize() {
      const rect = canvas.getBoundingClientRect();
      if (rect.width === 0 || rect.height === 0) return;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.floor(rect.width * dpr);
      canvas.height = Math.floor(rect.height * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);

      cols = Math.max(1, Math.floor(rect.width / cellSize));
      rows = Math.max(1, Math.floor(rect.height / cellSize));
      current = new Uint8Array(cols * rows);
      next = new Uint8Array(cols * rows);
      seed();
      draw();
    }

    function step() {
      for (let y = 0; y < rows; y++) {
        for (let x = 0; x < cols; x++) {
          let n = 0;
          for (let dy = -1; dy <= 1; dy++) {
            for (let dx = -1; dx <= 1; dx++) {
              if (dx === 0 && dy === 0) continue;
              const nx = (x + dx + cols) % cols;
              const ny = (y + dy + rows) % rows;
              n += current[idx(nx, ny)];
            }
          }
          const alive = current[idx(x, y)] === 1;
          next[idx(x, y)] = alive ? (n === 2 || n === 3 ? 1 : 0) : n === 3 ? 1 : 0;
        }
      }
      const tmp = current;
      current = next;
      next = tmp;
    }

    function draw() {
      const w = canvas.width / dpr;
      const h = canvas.height / dpr;
      ctx!.clearRect(0, 0, w, h);

      for (let y = 0; y < rows; y++) {
        for (let x = 0; x < cols; x++) {
          if (current[idx(x, y)] === 1) {
            ctx!.fillStyle = palette[(x + y) % palette.length];
            ctx!.fillRect(x * cellSize, y * cellSize, cellSize - 1, cellSize - 1);
          }
        }
      }
    }

    // Click to splash new life — tactile like the old site
    function handleClick(e: MouseEvent) {
      const rect = canvas.getBoundingClientRect();
      const x = Math.floor((e.clientX - rect.left) / cellSize);
      const y = Math.floor((e.clientY - rect.top) / cellSize);
      for (let dy = -3; dy <= 3; dy++) {
        for (let dx = -3; dx <= 3; dx++) {
          if (Math.random() < 0.45) {
            const nx = (x + dx + cols) % cols;
            const ny = (y + dy + rows) % rows;
            current[idx(nx, ny)] = 1;
          }
        }
      }
      draw();
    }
    canvas.addEventListener('click', handleClick);

    // Loop
    let last = 0;
    const interval = 140;
    let running = true;
    let rafId = 0;

    function tick(ts: number) {
      if (!running) return;
      if (ts - last > interval) {
        step();
        draw();
        last = ts;
      }
      rafId = requestAnimationFrame(tick);
    }

    // Pause when out of view (power-friendly on blog/contact backlinks)
    const io = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting && !running) {
          running = true;
          rafId = requestAnimationFrame(tick);
        } else if (!entry.isIntersecting && running) {
          running = false;
          cancelAnimationFrame(rafId);
        }
      }
    });
    io.observe(canvas);

    const ro = new ResizeObserver(resize);
    ro.observe(canvas);

    resize();
    rafId = requestAnimationFrame(tick);
  }

  document.querySelectorAll<HTMLCanvasElement>('canvas[data-gol]').forEach(startGol);
</script>

<style>
  .gol-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: auto; /* allow click-to-splash */
    z-index: 1;
    mix-blend-mode: multiply;
    opacity: 0.85;
  }
</style>
