---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact — Robby Boney" description="Say hello, propose a build, or just wave.">
  <div class="page page-narrow">
    <article class="card contact-card reveal r1">
      <div class="tag"><span class="pip"></span>Contact</div>
      <h1 class="contact-title">Let's <em>build something</em>.</h1>
      <p class="contact-sub">
        Fastest line is email. I answer most things within a day or two, unless I'm deep in a build.
      </p>

      <div class="contact-actions">
        <a class="email-row" href="mailto:robby.b@magicpilllabs.com">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="4" width="20" height="16" rx="2" />
            <path d="m22 6-10 7L2 6" />
          </svg>
          robby.b@magicpilllabs.com
        </a>
        <a class="email-row subtle" href="https://www.linkedin.com/in/robby-boney-717486133/" target="_blank" rel="noopener">
          LinkedIn ↗
        </a>
      </div>
    </article>

    <Footer />
  </div>
</BaseLayout>

<style>
  .contact-card {
    padding: 56px 48px;
    cursor: default;
    background:
      linear-gradient(135deg, rgba(255, 138, 91, 0.18), rgba(245, 215, 110, 0.12)),
      rgba(253, 250, 245, 0.7);
  }
  .contact-card:hover { transform: none; }
  .contact-card .tag { top: 24px; left: 28px; }

  .contact-title {
    font-family: var(--display);
    font-weight: 400;
    font-size: clamp(44px, 5.5vw, 68px);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--ink);
    margin-top: 12px;
  }
  .contact-title em {
    font-style: italic;
    background: linear-gradient(105deg, var(--aurora-6) 0%, var(--aurora-1) 50%, var(--aurora-3) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .contact-sub {
    font-family: var(--display);
    font-style: italic;
    font-weight: 300;
    font-size: 19px;
    color: var(--ink-soft);
    margin-top: 18px;
    max-width: 50ch;
  }
  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }
  .email-row {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 22px;
    border: 1px solid var(--line);
    border-radius: 100px;
    background: rgba(253, 250, 245, 0.85);
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--ink);
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .email-row:hover {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
    transform: translateY(-1px);
  }
  .email-row.subtle {
    background: transparent;
    color: var(--ink-soft);
  }

  @media (max-width: 700px) {
    .contact-card { padding: 40px 24px; }
  }
</style>
