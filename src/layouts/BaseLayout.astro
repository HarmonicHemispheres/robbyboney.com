---
import '../styles/global.css';
import Aurora from '../components/Aurora.astro';
import Nav from '../components/Nav.astro';

export interface Props {
  title: string;
  description?: string;
  showNav?: boolean;
  bodyClass?: string;
}

const {
  title,
  description = 'Robby Boney — builder, founder of MagicPill Labs. Software is moving from artifact to apparatus.',
  showNav = true,
  bodyClass = '',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/png" href="/logo.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=JetBrains+Mono:wght@300;400;500&family=Fraunces:ital,wght@0,300;0,400;0,500;0,600;0,900;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- Vercel Analytics (optional, no-op if not deployed there) -->
    <script is:inline>
      window.va =
        window.va ||
        function () {
          (window.vaq = window.vaq || []).push(arguments);
        };
    </script>
    <script is:inline defer src="/_vercel/insights/script.js"></script>
  </head>
  <body class={bodyClass}>
    <Aurora />
    {showNav && <Nav />}
    <slot />
  </body>
</html>
